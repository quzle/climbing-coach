# Your Supabase project URL.
# Found in: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anonymous (public) key.
# Found in: Supabase Dashboard → Project Settings → API → Project API Keys → anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your Supabase service role (secret) key. Never expose this to the browser.
# Found in: Supabase Dashboard → Project Settings → API → Project API Keys → service_role
SUPABASE_SECRET_KEY=

# Your Google Gemini API key.
# Found in: Google AI Studio → Get API Key (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# The public base URL of this application (e.g. http://localhost:3000 for local dev).
# Set to your production domain when deploying (e.g. https://yourapp.com)
NEXT_PUBLIC_APP_URL=
